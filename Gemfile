source "https://rubygems.org"

# Jekyll itself. GitHub Pages is built from a custom GitHub Actions workflow
# (see .github/workflows/jekyll.yml), so we are free to use a current Jekyll.
gem "jekyll", "~> 4.3"

# WEBrick is no longer bundled with Ruby 3+, needed for `jekyll serve`.
gem "webrick", "~> 1.8"

group :jekyll_plugins do
  gem "jekyll-sitemap", "~> 1.4"
end
